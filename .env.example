# At least one of these is required for the /api/compile route.
# - ANTHROPIC_API_KEY is used when the header toggle is set to "claude"
#   (Claude 3.5 Sonnet, with prompt caching). It is also used by the
#   Haiku judge that populates metrics.confidence_score.
# - OPENAI_API_KEY is used when the header toggle is set to "openai"
#   (GPT-4o, with automatic prompt caching).
# - GEMINI_API_KEY is used when the header toggle is set to "gemini"
#   (Gemini 2.5 Flash, with implicit prefix caching).
#
# If a key is missing for a mode, the route returns 503 with a clear
# message — pick whichever provider(s) you want to start with.

# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=...
